{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BudgetEvent",
  "type": "object",
  "required": [
    "ts",
    "run_id",
    "role",
    "model",
    "task",
    "total_tokens"
  ],
  "properties": {
    "ts": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "completion_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    },
    "tool_uses": {
      "type": "integer",
      "minimum": 0
    },
    "duration_sec": {
      "type": "number",
      "minimum": 0
    },
    "estimated_cost_cents": {
      "type": "integer",
      "minimum": 0
    }
  }
}