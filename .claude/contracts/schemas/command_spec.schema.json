{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandSpec",
  "type": "object",
  "required": [
    "type",
    "id",
    "command",
    "cwd",
    "expected_exit_codes",
    "timeout_seconds"
  ],
  "properties": {
    "type": {
      "const": "command_spec"
    },
    "id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "expected_exit_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "integer"
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600
    },
    "artifacts_expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}