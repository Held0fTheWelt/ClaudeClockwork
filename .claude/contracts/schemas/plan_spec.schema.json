{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanSpec",
  "type": "object",
  "required": [
    "type",
    "goal",
    "constraints",
    "tasks",
    "acceptance",
    "risk",
    "trust_mode"
  ],
  "properties": {
    "type": {
      "const": "plan_spec"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "steps"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "maxItems": 5
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_required": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "enum": [
        "low",
        "med",
        "high",
        "critical"
      ]
    },
    "trust_mode": {
      "enum": [
        "inherit",
        "verify",
        "rebuild"
      ]
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}