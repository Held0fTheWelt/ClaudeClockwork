{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FixPlanSpec",
  "type": "object",
  "required": [
    "type",
    "run_id",
    "issues",
    "plan",
    "rerun"
  ],
  "properties": {
    "type": {
      "const": "fixplan_spec"
    },
    "run_id": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "action"
        ],
        "properties": {
          "step": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "rerun": {
      "type": "object",
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected": {
          "type": "string"
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "string"
    }
  }
}