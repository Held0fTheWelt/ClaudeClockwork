{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PerformanceBudgetingConfig",
  "type": "object",
  "required": [
    "enabled",
    "include_self_costs",
    "print_cli",
    "export_charts",
    "output_dir",
    "events_sources_template",
    "top_n",
    "auto_disable"
  ],
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "include_self_costs": {
      "type": "boolean"
    },
    "print_cli": {
      "type": "boolean"
    },
    "export_charts": {
      "type": "boolean"
    },
    "output_dir": {
      "type": "string"
    },
    "events_sources_template": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "top_n": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "auto_disable": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "disable_if_total_tokens_gte": {
          "type": "integer",
          "minimum": 0
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}