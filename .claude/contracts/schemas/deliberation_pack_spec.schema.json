{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliberationPackSpec",
  "type": "object",
  "required": [
    "type",
    "pack_id",
    "purpose",
    "inputs",
    "summary",
    "snippets",
    "questions"
  ],
  "properties": {
    "type": {
      "const": "deliberation_pack_spec"
    },
    "pack_id": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "properties": {
        "plan": {
          "type": "string"
        },
        "routing_spec": {
          "type": "string"
        },
        "quality_signal": {
          "type": "string"
        },
        "ops_ledger_summary": {
          "type": "string"
        },
        "critic_report": {
          "type": "string"
        },
        "logs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "string"
      }
    },
    "snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "content"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "maxLength": 8000
          }
        },
        "additionalProperties": false
      }
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}