{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkerJobEnvelope",
  "description": "Phase 35 — Job envelope for distributed workers",
  "type": "object",
  "required": ["job_id", "idempotency_key", "node_spec"],
  "properties": {
    "job_id": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "node_spec": {
      "type": "object",
      "description": "skill/tool/agent spec"
    },
    "input_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "description": "content hash" }
    },
    "resource_hints": {
      "type": "object",
      "properties": {
        "cpu": { "type": "string" },
        "gpu": { "type": "boolean" },
        "timeout_seconds": { "type": "number" }
      }
    },
    "security_context": {
      "type": "object",
      "properties": {
        "allowed_roots": { "type": "array", "items": { "type": "string" } },
        "capabilities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "expected_output_schema": { "type": "object" }
  }
}
