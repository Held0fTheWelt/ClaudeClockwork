{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IdeaSetSpec",
  "type": "object",
  "required": [
    "type",
    "idea_set_id",
    "prompt",
    "ideas",
    "top_picks"
  ],
  "properties": {
    "type": {
      "const": "idea_set_spec"
    },
    "idea_set_id": {
      "type": "string"
    },
    "prompt": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "headline"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "headline": {
            "type": "string"
          },
          "tag": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "idea_ids"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "idea_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "top_picks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "idea_id",
          "reason",
          "expected_value",
          "risk"
        ],
        "properties": {
          "idea_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "expected_value": {
            "enum": [
              "low",
              "med",
              "high"
            ]
          },
          "risk": {
            "enum": [
              "low",
              "med",
              "high"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}