{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HardeningReport",
  "type": "object",
  "required": [
    "type",
    "generated_at",
    "scenarios",
    "findings",
    "fixes",
    "brain_updates",
    "warnings",
    "limitations"
  ],
  "properties": {
    "type": {
      "const": "hardening_report"
    },
    "generated_at": {
      "type": "string"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path",
          "details",
          "severity"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "error"
            ]
          }
        }
      }
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path",
          "action",
          "status"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "applied",
              "skipped",
              "failed"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "brain_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}