{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportSpec",
  "type": "object",
  "required": [
    "type",
    "run_id",
    "status",
    "artifacts",
    "summary"
  ],
  "properties": {
    "type": {
      "const": "report_spec"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "summary": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "path"
        ],
        "properties": {
          "type": {
            "enum": [
              "report",
              "changelog",
              "metrics",
              "runlog",
              "diff_summary"
            ]
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}