{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TasklistSpec",
  "type": "object",
  "required": [
    "type",
    "run_id",
    "confidence",
    "tasks",
    "unknowns",
    "assumptions",
    "pack_hints"
  ],
  "properties": {
    "type": {
      "const": "tasklist_spec"
    },
    "run_id": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "capability",
          "acceptance"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "capability": {
            "type": "string"
          },
          "acceptance": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pack_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "digest": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  }
}