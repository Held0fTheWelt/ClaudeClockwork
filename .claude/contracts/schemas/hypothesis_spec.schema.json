{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HypothesisSpec",
  "type": "object",
  "required": [
    "type",
    "id",
    "hypotheses"
  ],
  "properties": {
    "type": {
      "const": "hypothesis_spec"
    },
    "id": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "hypotheses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "success_signal"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "success_signal": {
            "type": "string"
          },
          "risk": {
            "enum": [
              "low",
              "med",
              "high"
            ],
            "default": "low"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}