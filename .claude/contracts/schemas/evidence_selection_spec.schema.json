{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceSelectionSpec",
  "type": "object",
  "required": [
    "type",
    "selection_id",
    "requested_action",
    "include",
    "snippets",
    "exclude",
    "reason"
  ],
  "properties": {
    "type": {
      "const": "evidence_selection_spec"
    },
    "selection_id": {
      "type": "string"
    },
    "requested_action": {
      "type": "string"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "range",
          "why"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "range": {
            "type": "string"
          },
          "why": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}